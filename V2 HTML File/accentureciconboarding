      "<div class=\"isln\">"+cat.label+"</div><div class=\"islsb\">"+d+"/"+t+" tasks</div>"+badge+"</div>";
    div.addEventListener("click",(function(id){return function(){openCat(id);};})(cat.id));
    m.appendChild(div);
  });
}
function swView(v){
  _curView=v;E("vtgr").classList.toggle("active",v==="grid");E("vtmp").classList.toggle("active",v==="map");
  E("hgrid").style.display=v==="grid"?"grid":"none";
  var mp=E("hmap");mp.style.display=v==="map"?"block":"none";
  if(v==="map")mp.style.minHeight="560px";
}
function openCat(id){
  _curCat=id;var cat=CATS.find(function(c){return c.id===id;});
  E("vh").style.display="none";E("vco").style.display="none";E("vc").style.display="block";
  E("cvt").textContent=cat.label;
  document.querySelectorAll(".sbi").forEach(function(e){e.classList.remove("active");});
  var si=E("sbi"+id);if(si)si.classList.add("active");
  renderTasks(cat);renderCm(id);updCvSub(cat);
}
function renderTasks(cat){
  var list=E("tlist");if(!list)return;list.innerHTML="";
  cat.tasks.forEach(function(task,i){
    var isDone=_done[cat.id]&&_done[cat.id].has(i);
    var tagCls={priority:"tp",social:"ts",admin:"ta",resource:"tr"}[task.tag]||"tr";
    var vid=task.video?"<div class=\"vid\" onclick=\"alert('Video placeholder - add real URL here.')\"><div class=\"vidp\"><svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\"/></svg></div><div class=\"vidc\">"+task.videoLabel+"</div></div>":"";
    var div=document.createElement("div");div.className="ti"+(isDone?" done":"");
    div.innerHTML="<div class=\"tcb\"><svg viewBox=\"0 0 11 11\"><path d=\"M1.5 5.5l2.5 2.5 5.5-5.5\"/></svg></div>"+
      "<div class=\"tb2\"><div class=\"till\">"+task.ill+"</div>"+
      "<div class=\"tnm\">"+task.name+"</div><div class=\"tds\">"+task.desc+"</div>"+
      "<span class=\"ttg "+tagCls+"\">"+TAGS[task.tag]+"</span>"+vid+"</div>";
    var cb=div.querySelector(".tcb");
    cb.addEventListener("click",(function(cid,idx){return function(){toggleTask(cid,idx);};})(cat.id,i));
    list.appendChild(div);
  });
}
function updCvSub(cat){var d=_done[cat.id]?_done[cat.id].size:0;E("cvs").textContent=d+" of "+cat.tasks.length+" tasks completed";}
function toggleTask(catId,idx){
  var s=_done[catId];if(s.has(idx))s.delete(idx);else s.add(idx);
  var cat=CATS.find(function(c){return c.id===catId;});
  renderTasks(cat);updCvSub(cat);buildSB();buildGrid();if(_curView==="map")buildMap();updProg();
  var si=E("sbi"+catId);if(si)si.classList.add("active");
  var total=CATS.reduce(function(s,c){return s+c.tasks.length;},0);
  var done=CATS.reduce(function(s,c){return s+(_done[c.id]?_done[c.id].size:0);},0);
  if(done===total){E("vc").style.display="none";E("vco").style.display="flex";}
}
function updProg(){
  var total=CATS.reduce(function(s,c){return s+c.tasks.length;},0);
  var done=CATS.reduce(function(s,c){return s+(_done[c.id]?_done[c.id].size:0);},0);
  var pct=Math.round(done/total*100);
  E("ppf").style.width=pct+"%";E("ppc").textContent=pct+"%";
  E("std").textContent=done;
  E("sts").textContent=CATS.filter(function(c){return _done[c.id]&&_done[c.id].size===c.tasks.length;}).length;
}
function showHome(){
  _curCat=null;E("vc").style.display="none";E("vco").style.display="none";E("vh").style.display="block";
  document.querySelectorAll(".sbi").forEach(function(e){e.classList.remove("active");});
  buildGrid();if(_curView==="map")buildMap();
}
function renderCm(id){
  var list=E("cmlist");if(!list)return;var c=_comments[id]||[];
  if(!c.length){list.innerHTML="<div style=\"font-size:12px;color:#C8C8C8;text-align:center;padding:10px\">No notes yet - be the first!</div>";return;}
  list.innerHTML=c.map(function(x){return "<div class=\"cmc\"><div class=\"cmm\"><div class=\"cmav\">"+x.initials+"</div><span class=\"cmau\">"+x.author+"</span><span class=\"cmti\">"+x.time+"</span></div><div class=\"cmtx\">"+x.text+"</div></div>";}).join("");
}
function postCm(){
  var inp=E("cmin");if(!inp)return;var text=inp.value.trim();if(!text||!_curCat)return;
  _comments[_curCat].unshift({author:_uN,initials:_uN.slice(0,2).toUpperCase(),time:"Just now",text:text});
  inp.value="";renderCm(_curCat);
}
function toggleChat(){E("cbp").classList.toggle("open");}
function addMsg(type,text,id){
  var msgs=E("cbms");if(!msgs)return null;
  var div=document.createElement("div");div.className="mg "+type;if(id)div.id=id;
  div.innerHTML="<div class=\"bub\">"+text+"</div>";
  msgs.appendChild(div);msgs.scrollTop=msgs.scrollHeight;return div;
}
function saveKey(){
  var k=E("cbki").value.trim();if(!k)return;_apiKey=k;
  E("cbki").value="<br>●●●●●●●●●●●●●●●●";
  E("cbst").textContent="AI mode active - full Claude knowledge base enabled";E("cbst").className="cbst on";
  addMsg("bot","API key saved! I am now powered by Claude with the full CIC knowledge base. Ask me anything.");
}
function fallback(q){
  q=q.toLowerCase();var keys=Object.keys(FB);
  for(var i=0;i<keys.length;i++){if(q.indexOf(keys[i])!==-1)return FB[keys[i]];}
  return "That one is best raised at the weekly analyst session with Luke Brodie, or ask your buddy directly.";
}
function sendQ(q){
  q=(q||"").trim();if(!q)return;E("cbii").value="";
  var sg=document.querySelector(".cbsg");if(sg)sg.style.display="none";
  addMsg("usr",q);var typing=addMsg("bot","Typing...","cbtyp");if(typing)typing.classList.add("typ");
  if(_apiKey){
    _history.push({role:"user",content:q});
    fetch("https://api.anthropic.com/v1/messages",{method:"POST",
      headers:{"Content-Type":"application/json","x-api-key":_apiKey,"anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:400,system:SYSTEM,messages:_history})
    }).then(function(r){return r.json();}).then(function(data){
      var reply=data.error?"API error: "+data.error.message:data.content[0].text;
      if(!data.error)_history.push({role:"assistant",content:reply});
      var t=E("cbtyp");if(t){t.querySelector(".bub").textContent=reply;t.className="mg bot";t.removeAttribute("id");}
      E("cbms").scrollTop=9999;
    }).catch(function(e){var t=E("cbtyp");if(t){t.querySelector(".bub").textContent="Error: "+e.message;t.className="mg bot";t.removeAttribute("id");}});
  }else{
    setTimeout(function(){
      var reply=fallback(q);var t=E("cbtyp");
      if(t){t.querySelector(".bub").textContent=reply;t.className="mg bot";t.removeAttribute("id");}
      E("cbms").scrollTop=9999;
    },500);
  }
}
</script>
</body>
